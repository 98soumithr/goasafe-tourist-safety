# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/goasafe?schema=public"
REDIS_URL="redis://localhost:6379"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# AI - OpenAI for complaint categorization
OPENAI_API_KEY="sk-..."

# Translation - Google Cloud
GOOGLE_TRANSLATE_API_KEY="your-google-api-key"

# SMS - Twilio (international tourists)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1..."

# SMS - MSG91 (Indian numbers)
MSG91_AUTH_KEY="your-msg91-key"

# File Storage
AWS_S3_BUCKET="goasafe-evidence"
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"
AWS_REGION="ap-south-1"
