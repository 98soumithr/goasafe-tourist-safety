generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String  @id @default(cuid())
  email     String? @unique
  name      String?
  password  String?
  role      String  @default("tourist")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  officer   TourismOfficer?

  @@map("users")
}

model Tourist {
  id            String   @id @default(cuid())
  fullName      String   @map("full_name")
  nationality   String?
  phone         String   @unique
  email         String?
  preferredLang String   @default("en") @map("preferred_lang")
  createdAt     DateTime @default(now()) @map("created_at")

  complaints    Complaint[]

  @@map("tourists")
}

model TaxiPermit {
  id             String  @id @default(cuid())
  permitNumber   String  @unique @map("permit_number")
  driverName     String  @map("driver_name")
  driverPhone    String? @map("driver_phone")
  vehicleNumber  String  @map("vehicle_number")
  vehicleType    String? @map("vehicle_type")
  permitStatus   String  @default("active") @map("permit_status")
  zone           String?
  issuedDate     DateTime @map("issued_date")
  expiryDate     DateTime @map("expiry_date")
  complaintCount Int      @default(0) @map("complaint_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  complaints       Complaint[]
  blacklistEntries Blacklist[]

  @@map("taxi_permits")
}

model Complaint {
  id                   String   @id @default(cuid())
  complaintNumber      String   @unique @map("complaint_number")
  touristId            String?  @map("tourist_id")
  taxiPermitId         String?  @map("taxi_permit_id")

  category             String
  subcategory          String?
  severity             String   @default("medium")
  status               String   @default("open")

  originalText         String   @map("original_text")
  originalLanguage     String   @map("original_language")
  translatedText       String?  @map("translated_text")

  aiCategoryConfidence Float?   @map("ai_category_confidence")
  aiSummary            String?  @map("ai_summary")
  aiSentimentScore     Float?   @map("ai_sentiment_score")

  incidentLocation     String?  @map("incident_location")
  incidentLat          Float?   @map("incident_lat")
  incidentLng          Float?   @map("incident_lng")
  incidentDatetime     DateTime? @map("incident_datetime")
  fareCharged          Float?   @map("fare_charged")
  fareExpected         Float?   @map("fare_expected")

  evidenceUrls         String   @default("[]") @map("evidence_urls")

  createdAt            DateTime  @default(now()) @map("created_at")
  acknowledgedAt       DateTime? @map("acknowledged_at")
  resolvedAt           DateTime? @map("resolved_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tourist              Tourist?       @relation(fields: [touristId], references: [id])
  taxiPermit           TaxiPermit?    @relation(fields: [taxiPermitId], references: [id])
  escalations          Escalation[]
  smsLogs              SmsLog[]
  notifications        Notification[]

  @@map("complaints")
}

model TourismOfficer {
  id                 String   @id @default(cuid())
  userId             String?  @unique @map("user_id")
  name               String
  designation        String?
  phone              String
  email              String?
  zone               String
  isActive           Boolean  @default(true) @map("is_active")
  dutyStatus         String   @default("off_duty") @map("duty_status")
  currentLat         Float?   @map("current_lat")
  currentLng         Float?   @map("current_lng")
  lastLocationUpdate DateTime? @map("last_location_update")
  createdAt          DateTime @default(now()) @map("created_at")

  user               User?    @relation(fields: [userId], references: [id])
  escalations        Escalation[]

  @@map("tourism_officers")
}

model Escalation {
  id             String   @id @default(cuid())
  complaintId    String   @map("complaint_id")
  officerId      String   @map("officer_id")
  escalationType String   @map("escalation_type")
  priority       Int      @default(1)
  notes          String?
  status         String   @default("pending")
  assignedAt     DateTime @default(now()) @map("assigned_at")
  acceptedAt     DateTime? @map("accepted_at")
  completedAt    DateTime? @map("completed_at")

  complaint      Complaint      @relation(fields: [complaintId], references: [id])
  officer        TourismOfficer @relation(fields: [officerId], references: [id])

  @@map("escalations")
}

model Blacklist {
  id              String   @id @default(cuid())
  taxiPermitId    String   @map("taxi_permit_id")
  reason          String
  complaintIds    String   @default("[]") @map("complaint_ids")
  totalComplaints Int      @map("total_complaints")
  blacklistedAt   DateTime @default(now()) @map("blacklisted_at")
  reviewDate      DateTime? @map("review_date")
  status          String   @default("active")
  reportWeek      DateTime @map("report_week")

  taxiPermit      TaxiPermit @relation(fields: [taxiPermitId], references: [id])

  @@map("blacklist")
}

model SmsLog {
  id             String    @id @default(cuid())
  complaintId    String?   @map("complaint_id")
  recipientPhone String    @map("recipient_phone")
  messageType    String    @map("message_type")
  messageBody    String    @map("message_body")
  language       String    @default("en")
  provider       String
  providerMsgId  String?   @map("provider_msg_id")
  status         String    @default("queued")
  sentAt         DateTime? @map("sent_at")
  deliveredAt    DateTime? @map("delivered_at")
  latencyMs      Int?      @map("latency_ms")
  createdAt      DateTime  @default(now()) @map("created_at")

  complaint      Complaint? @relation(fields: [complaintId], references: [id])

  @@map("sms_log")
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  title       String
  message     String
  complaintId String?  @map("complaint_id")
  targetRole  String   @default("admin") @map("target_role")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  complaint   Complaint? @relation(fields: [complaintId], references: [id])

  @@map("notifications")
}
